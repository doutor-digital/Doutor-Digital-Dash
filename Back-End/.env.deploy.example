# Modelo do arquivo de ambiente do deploy. O arquivo real vive SÓ na VPS, em
# /opt/doutordigital/api/.env com permissão 600 — nunca é commitado.
#
#   scp .env.deploy.example root@89.116.214.130:/opt/doutordigital/api/.env
#   ssh root@89.116.214.130 'chmod 600 /opt/doutordigital/api/.env'
#   (e então edite os valores lá dentro)

# Dono do repositório no GHCR, em minúsculas.
GHCR_OWNER=doutor-digital

# Tag da imagem. O CI sobrescreve com o SHA do commit a cada deploy; `latest`
# só serve para subir à mão.
IMAGE_TAG=latest

# Domínios. Enquanto valida na VPS use os subdomínios novos; só troque para
# api.doutordigitalconsultoria.com depois que a virada estiver decidida.
API_DOMAIN=api-vps.doutordigitalconsultoria.com
DASHBOARD_DOMAIN=dash-kommo.doutordigitalconsultoria.com

# Postgres já existente na VPS (stack `postgres`, alias de rede `postgres`).
POSTGRES_DB=leadanalytics
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# Chave HMAC do JWT, em base64. Gere uma NOVA — a que está no appsettings.json
# está versionada no git e deve ser considerada comprometida:
#   openssl rand -base64 32
JWT_SECRET=

# Senha do visualizador de logs (/logs).
LOGS_AUTH_PASSWORD=

# Resend (envio de e-mail). Deixe vazio para desativar.
RESEND_API_KEY=
